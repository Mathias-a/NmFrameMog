{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/simenseeberg/Documents/NmFrameMog && uv run ruff check --fix --quiet . 2>/dev/null; uv run ruff format --quiet . 2>/dev/null; true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(uv run ruff check:*)",
      "Bash(uv run ruff format:*)",
      "Bash(uv run mypy)",
      "Bash(uv run pytest:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(uv run python:*)",
      "Bash(git:*)"
    ]
  }
}
