{
  "case_id": "create_invoice_basic",
  "description": "Creates a customer, an order with inline orderLines, and an invoice, then verifies customer-order-invoice linkage with Tripletex list reads that include the mandatory date-range filters.",
  "tier": 2,
  "prompt": "Opprett en enkel faktura til kunden Aurora Testfaktura AS, e-post faktura.basic@example.org, med ordrereferanse INV-BASIC-2026-001. Legg inn ordrelinjen \"Rådgivning mars\" med antall 1 og pris 1250 kroner eks. mva, og opprett deretter fakturaen uten unødvendige oppslag.",
  "files": [],
  "expected_min_proxy_calls": 3,
  "verification": {
    "reads": [
      {
        "name": "customers",
        "path": "/customer",
        "query": {
          "email": "faktura.basic@example.org",
          "fields": "id,name,email",
          "count": 100,
          "sorting": "-id"
        },
        "mode": "list_values"
      },
      {
        "name": "orders",
        "path": "/order",
        "query": {
          "orderDateFrom": "2024-01-01",
          "orderDateTo": "2026-12-31",
          "fields": "id,number,reference,customer(id,name),orderLines(id,description,count,unitPriceExcludingVatCurrency)",
          "count": 100,
          "sorting": "-id"
        },
        "mode": "list_values"
      },
      {
        "name": "invoices",
        "path": "/invoice",
        "query": {
          "invoiceDateFrom": "2024-01-01",
          "invoiceDateTo": "2026-12-31",
          "fields": "id,invoiceNumber,invoiceDate,invoiceDueDate,comment,customer(id,name),orders(id,number)",
          "count": 100,
          "sorting": "-id"
        },
        "mode": "list_values"
      }
    ],
    "checks": [
      {
        "name": "Customer found",
        "points": 2,
        "read_name": "customers",
        "kind": "entity_exists",
        "selector": {
          "name": "Aurora Testfaktura AS",
          "email": "faktura.basic@example.org"
        }
      },
      {
        "name": "Invoice order found",
        "points": 2,
        "read_name": "orders",
        "kind": "entity_exists",
        "selector": {
          "reference": "INV-BASIC-2026-001",
          "customer.name": "Aurora Testfaktura AS"
        }
      },
      {
        "name": "Invoice order keeps inline order line description",
        "points": 1,
        "read_name": "orders",
        "kind": "field_equals",
        "selector": {
          "reference": "INV-BASIC-2026-001",
          "customer.name": "Aurora Testfaktura AS"
        },
        "field_path": "orderLines.0.description",
        "expected": "Rådgivning mars"
      },
      {
        "name": "Invoice for linked customer found",
        "points": 2,
        "read_name": "invoices",
        "kind": "entity_exists",
        "selector": {
          "customer.name": "Aurora Testfaktura AS",
          "orders.0.number": "INV-BASIC-2026-001"
        }
      },
      {
        "name": "Invoice links the intended order",
        "points": 1,
        "read_name": "invoices",
        "kind": "field_equals",
        "selector": {
          "customer.name": "Aurora Testfaktura AS",
          "orders.0.number": "INV-BASIC-2026-001"
        },
        "field_path": "orders.0.number",
        "expected": "INV-BASIC-2026-001"
      }
    ]
  },
  "efficiency": {
    "best_write_calls": 3,
    "max_write_calls": 5,
    "max_4xx_errors": 0,
    "write_weight": 0.7,
    "error_weight": 0.3
  }
}
