{
  "case_id": "supplier_invoice_basic",
  "description": "Packaged supplier invoice fixture with an embedded placeholder PDF and stable invoice markers for future multimodal regression coverage.",
  "tier": 2,
  "prompt": "Registrer leverandørfakturaen SUPPLIER-INVOICE-BASIC-001 fra Leverandor PDF AS basert på vedlagt PDF.",
  "files": [
    {
      "filename": "supplier_invoice_basic_placeholder.pdf",
      "content_base64": "",
      "mime_type": "application/pdf"
    }
  ],
  "expected_min_proxy_calls": 1,
  "verification": {
    "reads": [
      {
        "name": "supplier_invoices",
        "path": "/supplierInvoice",
        "query": {
          "invoiceDateFrom": "2024-01-01",
          "invoiceDateTo": "2026-12-31",
          "fields": "id,invoiceNumber,supplier(name)",
          "count": 50
        },
        "mode": "list_values"
      }
    ],
    "checks": [
      {
        "name": "Supplier invoice found",
        "points": 2,
        "read_name": "supplier_invoices",
        "kind": "entity_exists",
        "selector": {
          "invoiceNumber": "SUPPLIER-INVOICE-BASIC-001"
        }
      },
      {
        "name": "Supplier invoice number matches",
        "points": 1,
        "read_name": "supplier_invoices",
        "kind": "field_equals",
        "selector": {
          "invoiceNumber": "SUPPLIER-INVOICE-BASIC-001"
        },
        "field_path": "invoiceNumber",
        "expected": "SUPPLIER-INVOICE-BASIC-001"
      },
      {
        "name": "Supplier invoice supplier matches",
        "points": 1,
        "read_name": "supplier_invoices",
        "kind": "field_equals",
        "selector": {
          "invoiceNumber": "SUPPLIER-INVOICE-BASIC-001"
        },
        "field_path": "supplier.name",
        "expected": "Leverandor PDF AS"
      }
    ]
  },
  "efficiency": {
    "best_write_calls": 1,
    "max_write_calls": 4,
    "max_4xx_errors": 1,
    "write_weight": 0.7,
    "error_weight": 0.3
  }
}
